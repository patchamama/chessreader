{
    "name": "chess-ebook/api",
    "description": "Chess Ebook Parser API",
    "type": "project",
    "license": "GPL-2.0-only",
    "require": {
        "php": "^8.5",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/slim-bridge": "^3.4",
        "doctrine/dbal": "^4.4",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.11",
        "p-chess/chess": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    },
    "audit": {
        "ignore": ["PKSA-y2cr-5h3j-g3ys"],
        "block-insecure": false
    }
}
